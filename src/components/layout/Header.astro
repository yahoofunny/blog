---
import Search from "@/components/Search.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
import { siteConfig } from "../../site.config";
---

<header class="group relative mb-28 flex flex-col items-start sm:ps-18" id="main-header">
	<!-- 第一行：Logo -->
	<div class="flex items-center">
		<a
			aria-current={Astro.url.pathname === "/" ? "page" : false}
			class="inline-flex items-center sm:relative sm:inline-block sm:grayscale sm:hover:filter-none"
			href="/"
		>
			<span class="text-xl font-bold sm:text-2xl">{siteConfig.title}</span>
		</a>
	</div>
	
	<!-- 👈 新增：隐藏的 checkbox 开关 -->
	<input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />
	
	<!-- 第二行：右侧按钮组 -->
	<div class="flex items-center gap-4 mt-4">
		<Search />
		<ThemeToggle />
		
		<!-- 👈 1. 汉堡菜单按钮：绑定到 checkbox -->
		<label for="mobile-menu-toggle" class="group relative h-7 w-7 cursor-pointer sm:invisible sm:hidden">
			<span class="sr-only">Open main menu</span>
			<svg
				aria-hidden="true"
				class="absolute start-1/2 top-1/2 h-full w-full -translate-x-1/2 -translate-y-1/2 transition-all peer-checked:scale-0 peer-checked:opacity-0"
				fill="none"
				focusable="false"
				id="line-svg"
				stroke="currentColor"
				stroke-width="1.5"
				viewBox="0 0 24 24"
				xmlns="http://www.w3.org/2000/svg"
			>
				<path d="M3.75 9h16.5m-16.5 6.75h16.5" stroke-linecap="round" stroke-linejoin="round"
				></path>
			</svg>
			<svg
				aria-hidden="true"
				class="absolute start-1/2 top-1/2 h-full w-full -translate-x-1/2 -translate-y-1/2 scale-0 opacity-0 transition-all peer-checked:scale-100 peer-checked:opacity-100"
				fill="none"
				focusable="false"
				id="cross-svg"
				stroke="currentColor"
				stroke-width="1.5"
				viewBox="0 0 24 24"
				xmlns="http://www.w3.org/2000/svg"
			>
				<path d="M6 18L18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"></path>
			</svg>
		</label>
		
		<!-- 👈 2. 背景遮罩：点击后关闭菜单 -->
		<label for="mobile-menu-toggle" class="fixed inset-0 bg-black/50 z-30 hidden peer-checked:block md:hidden cursor-pointer"></label>
	</div>
	
	<!-- 👈 3. 导航菜单：手机端隐藏，选中时显示 -->
	<nav
		aria-label="Main menu"
		class="fixed top-0 left-0 w-full h-full bg-global-bg z-40 transform -translate-x-full peer-checked:translate-x-0 transition-transform duration-300 md:hidden"
	>
		<div class="p-6 h-full flex flex-col justify-between">
			<div>
				<a
					href="/"
					class="block py-2 text-xl font-bold"
					onclick="document.getElementById('mobile-menu-toggle').checked = false"
				>
					{siteConfig.title}
				</a>
				<ul class="space-y-6 mt-8">
					<li>
						<a
							href="/"
							class="text-accent hover:underline block py-2"
							onclick="document.getElementById('mobile-menu-toggle').checked = false"
						>
							Home
						</a>
					</li>
					<li>
						<a
							href="/about/"
							class="text-accent hover:underline block py-2"
							onclick="document.getElementById('mobile-menu-toggle').checked = false"
						>
							About
						</a>
					</li>
					<li>
						<a
							href="/posts/"
							class="text-accent hover:underline block py-2"
							onclick="document.getElementById('mobile-menu-toggle').checked = false"
						>
							Blog
						</a>
					</li>
					<li>
						<a
							href="/notes/"
							class="text-accent hover:underline block py-2"
							onclick="document.getElementById('mobile-menu-toggle').checked = false"
						>
							Notes
						</a>
					</li>
				</ul>
			</div>
			<div class="text-center text-muted py-8">
				Find me on
				<div class="flex justify-center gap-4 mt-2">
					<a href="https://github.com/yahoofunny" target="_blank">
						<svg class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24">
							<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577 0-.285-.01-1.04-.015-2.04-3.338.726-4.043-1.61-4.043-1.61-.547-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.835 2.807 1.305 3.492.998.107-.776.418-1.305.762-1.604-2.665-.3-5.467-1.333-5.467-5.931 0-1.311.469-2.383 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.405 1.02.006 2.047.138 3.006.405 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.838 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.565 22.094 24 17.594 24 12.297c0-6.627-5.373-12-12-12"/>
						</svg>
					</a>
				</div>
			</div>
		</div>
	</nav>
</header>