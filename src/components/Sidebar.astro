---
// src/components/Sidebar.astro
---
<aside class="sidebar">
  <div class="sidebar-section">
    <h3>🏷️ 标签 (Tags)</h3>
    <ul class="tag-list">
      <li><a href="/tags/games/">#游戏</a></li>
      <li><a href="/tags/tech/">#技术</a></li>
      <li><a href="/tags/life/">#生活</a></li>
    </ul>
  </div>

  <div class="sidebar-section">
    <h3>📑 文章索引 (Index)</h3>
    <ul class="post-list">
      <li><a href="/posts/webmentions/">Webmentions 教程</a></li>
      <li><a href="/posts/first-post/">我的第一篇随笔</a></li>
    </ul>
  </div>
</aside>

<style>
  /* 纯粹的侧边栏卡片样式，去掉了所有手机端抽屉的脏代码 */
  .sidebar {
    background: var(--theme-bg, #1a1a1a); /* 自动适配你的暗黑/白天模式 */
    padding: 1.5rem;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
  }
  
  .sidebar-section {
    margin-bottom: 2rem;
  }
  
  .sidebar-section:last-child {
    margin-bottom: 0; /* 最后一个区块不留底边距 */
  }
  
  .sidebar h3 {
    font-size: 1.1rem;
    color: #4ade80; /* 清新的绿色标题 */
    margin-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 0.5rem;
    font-weight: 600;
  }
  
  .tag-list, .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .tag-list li, .post-list li {
    margin-bottom: 0.8rem;
  }
  
  .tag-list a, .post-list a {
    color: var(--theme-text, #ccc);
    text-decoration: none;
    font-size: 0.95rem;
    transition: all 0.2s ease;
    display: inline-block;
  }
  
  .tag-list a:hover, .post-list a:hover {
    color: #4ade80; /* 鼠标悬停时变成绿色 */
    transform: translateX(4px); /* 鼠标放上去时，文字微微向右滑动，超级丝滑！ */
  }
</style>