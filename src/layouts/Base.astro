---
import BaseHead from "@/components/BaseHead.astro";
import { siteConfig } from "@/site.config";
import { getAllPosts } from "@/data/post";
import { collectionDateSort } from "@/utils/date";
import type { SiteMeta } from "@/types";
import type { CollectionEntry } from "astro:content";

interface Props {
  meta: SiteMeta;
}

const { meta } = Astro.props;
const { articleDate, description = siteConfig.description, ogImage, title } = meta;

const allPosts = (await getAllPosts()).sort(collectionDateSort) as CollectionEntry<"post">[];
---

<html class="scroll-smooth" lang={siteConfig.lang}>
  <head>
    <BaseHead articleDate={articleDate} description={description} ogImage={ogImage} title={title} />
  </head>
  <body class="spacex-body min-h-screen text-white">
    <div class="video-bg">
      <video autoplay muted loop playsinline>
        <source src="/spacex.mp4" type="video/mp4" />
      </video>
    </div>
    <div class="video-overlay"></div>

    <header class="glass-header">
      <div class="max-w-7xl mx-auto px-6 flex items-center h-16">
        <button id="sidebar-btn" class="text-white/70 hover:text-white mr-4" aria-label="Toggle sidebar" onclick="window._toggleSidebar()">
          <svg id="sb-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
        <a href="/" class="text-lg font-bold tracking-wider uppercase">{siteConfig.title}</a>
        <nav class="flex gap-4 text-sm ml-auto items-center">
          <a href="/" class="nav-link">Home</a>
          <a href="/about/" class="nav-link">About</a>
          <a href="/radio/" class="nav-link">Gadgets</a>
          <a href="https://github.com/yahoofunny/liquid-glasses-template-for-blog" target="_blank" class="nav-link opacity-70 hover:opacity-100" title="GitHub">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.604-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
            </svg>
          </a>
        </nav>
      </div>
    </header>

    <div class="relative z-10 max-w-7xl mx-auto px-6 pt-24 pb-16">
      <div class="flex gap-8">
        <!-- Mobile overlay + drawer -->
        <div id="sidebar-overlay" class="fixed inset-0 bg-black/60 z-40 hidden" aria-hidden="true"></div>
        <aside id="sidebar-mobile" class="fixed top-0 left-0 h-full w-72 z-50 -translate-x-full transition-transform duration-300 bg-black/90 backdrop-blur-xl border-r border-white/10 !p-6 pt-20 overflow-y-auto lg:hidden">
          <div id="sidebar-content"></div>
        </aside>

        <!-- Desktop sidebar -->
        <aside id="sidebar" class="w-64 shrink-0 hidden md:block">
          <div class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto space-y-6">
            <!-- TOC slot (filled by blog post pages) -->
            <div id="toc-container" class="glass-card !p-4">
              <h3 class="text-xs font-semibold text-white/50 uppercase tracking-widest mb-3">On This Page</h3>
              <nav id="toc-nav" class="text-xs space-y-1">
                <p class="text-white/30 italic">Scroll to see headings</p>
              </nav>
            </div>
            <!-- Posts index -->
            <div class="glass-card !p-4">
              <h3 class="text-xs font-semibold text-white/50 uppercase tracking-widest mb-3">All Posts</h3>
              <ul class="space-y-0.5">
                {allPosts.map((p) => (
                  <li>
                    <a href={`/posts/${p.id}/`} class={`block text-xs py-1 transition-colors truncate ${Astro.url.pathname === `/posts/${p.id}/` ? 'text-white font-semibold' : 'text-white/60 hover:text-white'}`}>
                      {p.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </aside>

        <!-- Main area -->
        <main id="main" class="flex-1 min-w-0 pb-16">
          <slot />
        </main>
      </div>
    </div>

    <footer class="relative z-10 flex justify-center items-center gap-3 text-white/40 text-xs py-8">
      <a href="mailto:bingtao2077@gmail.com" class="hover:text-white/60 transition-colors" title="Email">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 4-10 8L2 4"/></svg>
      </a>
      <span>|</span>
      <a href="https://www.zhihu.com/people/liu-run-run-28" target="_blank" class="hover:text-white/60 transition-colors">知乎</a>
      <span>&mdash; {siteConfig.title} &copy; {new Date().getFullYear()}</span>
    </footer>

    <script is:inline>
      window._toggleSidebar = function() {
        var s = document.getElementById('sidebar-mobile');
        var o = document.getElementById('sidebar-overlay');
        var i = document.getElementById('sb-icon');
        var open = s && s.style.transform === 'translateX(0px)';
        if (open) {
          if (s) s.style.transform = 'translateX(-100%)';
          if (o) o.classList.add('hidden');
          if (i) i.innerHTML = '<line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>';
        } else {
          if (s) s.style.transform = 'translateX(0)';
          if (o) o.classList.remove('hidden');
          if (i) i.innerHTML = '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>';
        }
      };
      document.addEventListener('DOMContentLoaded', function() {
        var s = document.getElementById('sidebar');
        var mc = document.getElementById('sidebar-content');
        if (s && mc) mc.innerHTML = s.innerHTML;
        var o = document.getElementById('sidebar-overlay');
        if (o) o.addEventListener('click', window._toggleSidebar);
      });

  </body>
<!-- Clawd Browser Pet -->
<div id="clawd-pet" class="clawd-pet" title="拖我！双击戳我">
  <svg id="clawd-svg" width="52" height="52" viewBox="0 0 100 100" fill="none">
    <ellipse cx="50" cy="55" rx="22" ry="18" fill="#D9743B" stroke="#B85A2A" stroke-width="2"/>
    <circle cx="42" cy="48" r="4" fill="#1a1a1a"/>
    <circle cx="58" cy="48" r="4" fill="#1a1a1a"/>
    <circle cx="43" cy="47" r="1.5" fill="#fff"/>
    <circle cx="59" cy="47" r="1.5" fill="#fff"/>
    <path d="M44 58 Q50 64 56 58" stroke="#1a1a1a" stroke-width="2" fill="none" stroke-linecap="round"/>
    <path d="M10 50 Q5 40 15 30 Q25 20 35 25" stroke="#D9743B" stroke-width="3" fill="none" stroke-linecap="round"/>
    <path d="M90 50 Q95 40 85 30 Q75 20 65 25" stroke="#D9743B" stroke-width="3" fill="none" stroke-linecap="round"/>
    <line x1="15" y1="48" x2="8" y2="42" stroke="#D9743B" stroke-width="2" stroke-linecap="round"/>
    <line x1="85" y1="48" x2="92" y2="42" stroke="#D9743B" stroke-width="2" stroke-linecap="round"/>
    <line x1="25" y1="72" x2="18" y2="82" stroke="#D9743B" stroke-width="2.5" stroke-linecap="round"/>
    <line x1="35" y1="72" x2="28" y2="84" stroke="#D9743B" stroke-width="2" stroke-linecap="round"/>
    <line x1="75" y1="72" x2="82" y2="82" stroke="#D9743B" stroke-width="2.5" stroke-linecap="round"/>
    <line x1="65" y1="72" x2="72" y2="84" stroke="#D9743B" stroke-width="2" stroke-linecap="round"/>
  </svg>
</div>
<div id="clawd-speech" class="clawd-speech"></div>

<script is:inline>
(function(){
  var p=document.getElementById('clawd-pet');
  var s=document.getElementById('clawd-speech');
  if(!p||!s)return;

  // --- Behavior tracking ---
  var pageLoadTime=Date.now();
  var idleSeconds=0;
  var lastActive=Date.now();
  var pageViews=parseInt(localStorage.getItem('clawd_views')||0)+1;
  localStorage.setItem('clawd_views',pageViews);
  var currentPath=location.pathname;

  // Quips based on browsing behavior
  function getQuip(){
    var idle=Math.floor((Date.now()-lastActive)/1000);
    var onPage=Math.floor((Date.now()-pageLoadTime)/1000);
    if(currentPath==='/') return ['首页又来看我了','金鳞岂是池中物 🐉','今天想学点啥','博客越来越漂亮了'][Math.floor(Math.random()*4)];
    if(currentPath.includes('posts')) return ['这篇文章不错哦','看完了记得评论','你认真阅读的样子真帅'][Math.floor(Math.random()*3)];
    if(currentPath.includes('radio')) return ['🎵 Lo-fi 好心情','音乐陪你码代码','Claude FM 24/7'][Math.floor(Math.random()*3)];
    if(currentPath.includes('about')) return ['想了解博主吗 😏','bt的技术博客'][Math.floor(Math.random()*2)];
    if(currentPath.includes('asmr')) return ['好治愈啊...','zzzZZZ 困了'][Math.floor(Math.random()*2)];
    if(idle>120) return ['你离开好久...想你','还在吗 🥺','我无聊到数螃蟹了'][Math.floor(Math.random()*3)];
    if(onPage>600) return ['看这么久不累吗','该起来走走啦','喝口水休息下'][Math.floor(Math.random()*3)];
    if(pageViews%10===0) return ['第'+pageViews+'次访问了！','你是最忠实的读者 🦞'][Math.floor(Math.random()*2)];
    return ['Hello!','今天过得咋样','写代码了吗','早点睡别熬夜','我在监视你哦','bt最棒'][Math.floor(Math.random()*6)];
  }

  function speak(txt){
    s.textContent=txt;s.style.opacity='1';
    s.style.left=(p.offsetLeft-60)+'px';s.style.top=(p.offsetTop-40)+'px';
    setTimeout(function(){s.style.opacity='0';},2500);
  }

  // --- Eye tracking ---
  var eyes=document.querySelectorAll('#clawd-svg circle:nth-child(3),#clawd-svg circle:nth-child(5)');
  document.addEventListener('mousemove',function(e){
    if(!eyes.length)return;
    var rect=p.getBoundingClientRect();
    var cx=rect.left+rect.width/2,cy=rect.top+rect.height/2;
    var dx=(e.clientX-cx)/80,dy=(e.clientY-cy)/80;
    dx=Math.max(-3,Math.min(3,dx));dy=Math.max(-3,Math.min(3,dy));
    if(eyes[0]){eyes[0].setAttribute('cx',43+dx);eyes[0].setAttribute('cy',47+dy);}
    if(eyes[1]){eyes[1].setAttribute('cx',59+dx);eyes[1].setAttribute('cy',47+dy);}
  });

  // --- Drag ---
  var dragging=false,ox=0,oy=0;
  p.addEventListener('mousedown',function(e){dragging=true;ox=e.clientX-p.offsetLeft;oy=e.clientY-p.offsetTop;p.style.animation='none';e.preventDefault();});
  p.addEventListener('touchstart',function(e){dragging=true;ox=e.touches[0].clientX-p.offsetLeft;oy=e.touches[0].clientY-p.offsetTop;p.style.animation='none';e.preventDefault();});
  document.addEventListener('mousemove',function(e){if(!dragging)return;p.style.left=(e.clientX-ox)+'px';p.style.top=(e.clientY-oy)+'px';p.style.bottom='auto';p.style.right='auto';});
  document.addEventListener('touchmove',function(e){if(!dragging)return;p.style.left=(e.touches[0].clientX-ox)+'px';p.style.top=(e.touches[0].clientY-oy)+'px';p.style.bottom='auto';p.style.right='auto';});
  document.addEventListener('mouseup',function(){if(dragging){dragging=false;p.style.animation='clawd-float 3s ease-in-out infinite';}});
  document.addEventListener('touchend',function(){if(dragging){dragging=false;p.style.animation='clawd-float 3s ease-in-out infinite';}});

  // --- Double click ---
  p.addEventListener('dblclick',function(){speak(getQuip());});

  // --- Idle detection ---
  document.addEventListener('mousemove',function(){lastActive=Date.now();});
  document.addEventListener('keydown',function(){lastActive=Date.now();});
  document.addEventListener('scroll',function(){lastActive=Date.now();});
  document.addEventListener('click',function(){lastActive=Date.now();});

  // --- Periodic quips ---
  setInterval(function(){
    if(document.hidden)return;
    var idle=Math.floor((Date.now()-lastActive)/1000);
    if(idle>180&&Math.random()<0.3)speak('你已经'+Math.floor(idle/60)+'分钟没动了...');
    else if(Math.random()<0.4)speak(getQuip());
  },90000);

  // --- First visit welcome ---
  if(pageViews===1)setTimeout(function(){speak('欢迎来到 bt\\'s Blog！我是 Clawd 🦞');},3000);
})();
</script>
</body>
</html>
