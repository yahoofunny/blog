---
// 👇 这里是“邀请函”区域，告诉 Astro 去哪里找这些组件（之前报错就是因为漏了这里！）
import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/layout/Footer.astro";
import Header from "@/components/layout/Header.astro";
import SkipLink from "@/components/SkipLink.astro";
import ThemeProvider from "@/components/ThemeProvider.astro";
import Sidebar from "@/components/Sidebar.astro"; 
import { siteConfig } from "@/site.config";
import type { SiteMeta } from "@/types";

interface Props {
	meta: SiteMeta;
}

const {
	meta: { articleDate, description = siteConfig.description, ogImage, title },
} = Astro.props;
---

<html class="scroll-smooth" lang={siteConfig.lang}>
	<head>
		<BaseHead articleDate={articleDate} description={description} ogImage={ogImage} title={title} />
		<ThemeProvider />
	</head>
	<body class="bg-global-bg text-global-text min-h-screen font-mono text-sm font-normal antialiased">
		<SkipLink />
		<Header />
		
		<!-- 👇 1. 核心布局容器 (你写的完美代码) -->
		<div class="mx-auto max-w-7xl px-4 sm:px-8 pt-8 flex flex-col md:flex-row gap-8">
			
			<!-- 👇 2. 左侧边栏：手机上隐藏 (hidden)，电脑上显示 (md:block) -->
			<aside class="hidden md:block md:w-64 shrink-0">
				<div class="sticky top-24">
					<Sidebar />
				</div>
			</aside>

			<!-- 👇 3. 右侧主内容区 -->
			<main id="main" class="flex-1 min-w-0 pb-16">
				<slot />
			</main>
			
		</div>

		<Footer />
	</body>
</html>