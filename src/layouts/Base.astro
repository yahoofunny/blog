    <div id="clawd-pet" class="clawd-pet" title="Clawd"><img id="clawd-img" src="/clawd/clawd-idle.gif" style="width:80px;height:80px" draggable="false"/></div>
    <div id="clawd-speech" class="clawd-speech"></div>
    <script is:inline>
      (function(){
        var p=document.getElementById("clawd-pet"),b=document.getElementById("clawd-speech"),img=document.getElementById("clawd-img");
        if(!p||!b||!img)return;
        function setGif(n){img.src="/clawd/clawd-"+n+".gif"}
        var s="idle",la=Date.now(),al=0,pv=parseInt(localStorage.getItem("cv")||0)+1;localStorage.setItem("cv",pv);var cu=location.pathname;
        var isRadio=cu.indexOf("radio")>=0,isPost=cu.indexOf("posts")>=0;
        function ss(n){if(s===n)return;s=n;
          var m={idle:"idle",reading:"idle-reading",thinking:"thinking",typing:"typing",juggling:"juggling",sleeping:"sleeping",happy:"happy",error:"error",building:"building",sweeping:"sweeping",conducting:"conducting",headphones:"headphones-groove"}[n]||"idle";
          setGif(m);if(n==="sleeping"){p.style.opacity="0.4";p.style.filter="grayscale(0.6)"}else{p.style.opacity="1";p.style.filter="none"}
        }
        function ua(){
          if(s==="sleeping"||s==="happy"||s==="building")return;
          if(isRadio){ss("headphones");return}  // Radio: always headphones
          if(isPost&&al<6){ss("reading");return} // Posts: reading by default
          if(al>10)ss("juggling");               // Only extreme activity → juggling
          else if(al>7)ss("typing");             // Keyboard + heavy scroll → typing
          else if(al>4)ss("thinking");            // Moderate → thinking
          else if(al>1)ss("reading");             // Light → reading
          else if(Math.random()<0.03)ss("conducting");
          else ss("idle");
        }
        // Different boost per event type
        function onMouse(){al=Math.min(15,al+1);la=Date.now()}  // gentle
