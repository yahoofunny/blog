---
import BaseHead from "@/components/BaseHead.astro";
import SidebarContent from "@/components/SidebarContent.astro";
import { siteConfig } from "@/site.config";
import type { SiteMeta } from "@/types";

interface Props {
  meta: SiteMeta;
}

const { meta } = Astro.props;
const { articleDate, description = siteConfig.description, ogImage, title } = meta;
---

<html class="scroll-smooth" lang={siteConfig.lang}>
  <head>
    <BaseHead articleDate={articleDate} description={description} ogImage={ogImage} title={title} />
    <script is:inline>
      if (localStorage.getItem('theme') === 'light') {
        document.documentElement.classList.add('light');
      }
    </script>
  </head>
  <body class="spacex-body min-h-screen text-white">
    <!-- Hidden checkbox for mobile menu hamburger animation -->
    <input type="checkbox" id="menu-toggle" class="hidden" onchange="document.getElementById('mobile-menu').style.display=this.checked?'flex':'none'" />
    <script is:inline>
      var _zh2en={"Tags":"Tags","Archives":"Archives","About":"About","Gadgets":"Gadgets","知乎":"Zhihu","UPCOMING":"UPCOMING","LANGUAGE":"LANGUAGE","最新":"Newest","最早":"Oldest","A → Z":"A → Z","Z → A":"Z → A","Home":"Home","click it":"click it","On This Page":"On This Page","Scroll to see headings":"Scroll to see headings","Archive":"Archive","No sections":"No sections","All Posts":"All Posts","← Back to Home":"← Back to Home","技术博客":"Tech Blog","Claude FM":"Claude FM","24/7 Lo-fi & Ambient":"24/7 Lo-fi & Ambient","Powered by laut.fm":"Powered by laut.fm","Drone Zone":"Drone Zone","Dark Ambient — 伤感空间音乐":"Dark Ambient — Melancholic Space Music","SomaFM Drone Zone":"SomaFM Drone Zone","GAMES":"GAMES","AI":"AI","🎮 Godot 小游戏":"🎮 Godot Games","浏览器可直接玩的小游戏":"Playable browser games","🤖 MiniMind 模型调用":"🤖 MiniMind LLM","自训练轻量 LLM 对话":"Self-trained lightweight LLM","Godot 小游戏 · MiniMind 模型调用":"Godot Games · MiniMind LLM","数据结构、算法笔记 :)":"Data Structures & Algorithms Notes :)","金鳞岂是池中物，一遇风云便化龙":"\"A golden carp is no pond creature\"","bt's Blog :)\n":"bt's Blog :)\n","Hello!":"Hello!","今天过得咋样":"How's your day?","写代码了吗":"Coded anything?","早点睡别熬夜":"Sleep early!","bt最棒":"bt is the best!","🦞":"🦞","你是bt的朋友吗":"Are you bt's friend?","欢迎来到bt的网站":"Welcome to bt's website!","你是bt要等的人吗":"Are you the one?","一起加油呀":"Let's go!","有什么需要帮忙的吗":"Need any help?","这个博客真不错":"This blog is awesome!","我喜欢这里的音乐":"I love the music here!","好久不见呀":"Long time no see!","bt今天又更新博客了吗":"Did bt update the blog?","bt是个有趣的灵魂":"bt is an interesting soul!","跟着bt学数据结构":"Learn DSA with bt!","bt写代码的样子很帅":"bt looks cool coding!","这里永远是bt的精神自留地":"bt's sanctuary!","bt等你很久了":"bt waited for you!","bt的朋友就是我的朋友":"bt's friends = my friends!","有问题尽管问bt":"Ask bt anything!","bt的电路笔记超详细":"bt's circuit notes rock!","bt说早点睡别熬夜":"bt says sleep early!","给我发图片，点击下方按钮上传":"Send me images — click below!","打开图床 →":"Open Image Host →"};
      var _emoji={"开心":"😄","加油":"💪","谢谢":"🙏","喜欢":"❤️","厉害":"🔥","睡觉":"😴","吃饭":"🍚","朋友":"👫","音乐":"🎵","博客":"📝","代码":"💻","学习":"📚","游戏":"🎮","好":"👍","数据结构":"📊","算法":"🧮","电路":"⚡","笔记":"📝","Hello":"👋","Hi":"👋","Godot":"🕹️","MiniMind":"🧠","LLM":"🤖","Games":"🎲","Tech":"💻","Blog":"✍️","Music":"🎶","SpaceX":"🚀","RSS":"📡","Email":"📧","GitHub":"🐙","radio":"📻","FM":"🎙️","Dark":"🌑","Ambient":"🌌","Drone":"🛸","image":"📸","upload":"⬆️","click":"👆","friend":"🤝","code":"⌨️","data":"📊","algorithm":"🧮","circuit":"⚡","note":"📝","game":"🎲","love":"💕","happy":"😊","fun":"🎉","cool":"😎","star":"⭐","fire":"🔥","cat":"🐱","dog":"🐶","sun":"☀️","moon":"🌙","lofi":"🎧","24/7":"🕐"};
      var _kao=["(´・ω・`)","(◕‿◕)","(｡･ω･｡)","(≧∇≦)","(๑•̀ㅂ•́)و✧","(◍•ᴗ•◍)","(╯°□°）╯︵┻━┻","┐(´д`)┌","(￣▽￣)ノ","(✿◠‿◠)","(´▽`)ﾉ","(・∀・)","(◕ᴗ◕✿)","(｡•̀ᴗ-)✧","(◔‿◔)","(◠‿◠)","(─‿‿─)","(人◕ω◕)","(づ｡◕‿‿◕｡)づ","(ﾉ◕ヮ◕)ﾉ*:･ﾟ✧"];
      function _walkNodes(){
        var w=document.createTreeWalker(document.body,NodeFilter.SHOW_TEXT,null,false);
        var nodes=[],n;
        while(n=w.nextNode()){
          if(n.parentElement.closest('script,style,#mobile-menu,#clawd-pet,#clawd-speech,noscript'))continue;
          if(n.textContent.trim()){if(!n._orig)n._orig=n.textContent;nodes.push(n)}
        }
        return nodes;
      }
      window._setLang=function(lang){
        localStorage.setItem('lang',lang);
        var nodes=_walkNodes();
        // Restore
        nodes.forEach(function(n){n.textContent=n._orig});
        if(lang==='zh')return;
        nodes.forEach(function(n){
          var t=n.textContent;
          if(lang==='en'){
            var keys=Object.keys(_zh2en).sort(function(a,b){return b.length-a.length});
            for(var i=0;i<keys.length;i++){
              var k=keys[i];
              if(t.indexOf(k)>=0)t=t.split(k).join(_zh2en[k]);
            }
          }else if(lang==='emoji'){
            for(var k in _emoji){if(t.indexOf(k)>=0&&t.indexOf(_emoji[k])<0)t+=' '+_emoji[k]}
          }else if(lang==='kaomoji'){
            var kk=_kao[Math.floor(Math.random()*_kao.length)];
            t=t.replace(/([。！？；…\.\!\?\;])/g,'$1 '+kk+' ');
          }
          n.textContent=t;
        });
      };
    </script>

    <div class="video-bg">
      <video autoplay muted loop playsinline>
        <source src="/spacex.mp4" type="video/mp4" />
      </video>
    </div>
    <div class="video-overlay"></div>

    <header class="glass-header">
      <div class="w-full px-6 2xl:px-12 flex items-center h-16 relative">
        <a href="/" class="flex items-center">
          <img src="/smiley.svg" alt="bt" width="28" height="28" class="inline-block" style="filter: invert(47%) sepia(96%) saturate(3590%) hue-rotate(190deg) brightness(101%) contrast(101%)" />
        </a>

        <!-- Desktop nav (centered) -->
        <nav class="hidden lg:flex gap-4 text-sm items-center absolute left-1/2 -translate-x-1/2">
          <a href="/tags/" class="nav-link">Tags</a>
          <a href="/archives/" class="nav-link">Archives</a>
          <a href="/about/" class="nav-link">About</a>
          <a href="/radio/" class="nav-link">Gadgets</a>
        </nav>

        <!-- Desktop LANGUAGE dropdown -->
        <div class="hidden md:flex items-center mr-4 lang-dropdown">
          <span class="text-[10px] text-white/40 uppercase tracking-[0.2em] cursor-default select-none">LANGUAGE</span>
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ml-1 text-white/30"><polyline points="6 9 12 15 18 9"/></svg>
          <div class="lang-menu glass-card !p-3 !rounded-xl absolute top-full right-0 pt-0 min-w-[140px] z-[110]">
            <div class="lang-bridge"></div>
            <a href="javascript:void(0)" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-2 py-1.5 rounded transition-colors" onclick="window._setLang('zh');document.querySelectorAll('.lang-menu a').forEach(function(a){a.style.fontWeight='400'});this.style.fontWeight='700'">中 文</a>
            <a href="javascript:void(0)" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-2 py-1.5 rounded transition-colors" onclick="window._setLang('en');document.querySelectorAll('.lang-menu a').forEach(function(a){a.style.fontWeight='400'});this.style.fontWeight='700'">EN</a>
            <a href="javascript:void(0)" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-2 py-1.5 rounded transition-colors" onclick="window._setLang('emoji');document.querySelectorAll('.lang-menu a').forEach(function(a){a.style.fontWeight='400'});this.style.fontWeight='700'">😀 Emoji</a>
            <a href="javascript:void(0)" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-2 py-1.5 rounded transition-colors" onclick="window._setLang('kaomoji');document.querySelectorAll('.lang-menu a').forEach(function(a){a.style.fontWeight='400'});this.style.fontWeight='700'">(´・ω・`) 颜文字</a>
          </div>
        </div>

        <!-- Desktop UPCOMING dropdown -->
        <div class="hidden md:flex items-center mr-4 upcoming-dropdown">
          <span class="text-[10px] text-white/40 uppercase tracking-[0.2em] cursor-default select-none">UPCOMING</span>
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ml-1 text-white/30"><polyline points="6 9 12 15 18 9"/></svg>
          <div class="upcoming-menu glass-card !p-4 !rounded-xl absolute top-full right-0 pt-0 min-w-[220px] space-y-3 z-[110]">
            <div class="upcoming-bridge"></div>
            <a href="https://itch.io/games/made-with-godot/platform-web" target="_blank" class="block hover:bg-white/5 -mx-1 px-1 py-1 rounded-lg transition-colors">
              <p class="text-xs text-white/30 uppercase tracking-wider mb-1">GAMES</p>
              <p class="text-sm text-white/70">🎮 Godot 小游戏</p>
              <p class="text-[10px] text-white/30 mt-0.5">浏览器可直接玩的小游戏</p>
            </a>
            <a href="https://github.com/jingyaogong/minimind" target="_blank" class="block hover:bg-white/5 -mx-1 px-1 py-1 rounded-lg transition-colors border-t border-white/10 pt-3">
              <p class="text-xs text-white/30 uppercase tracking-wider mb-1">AI</p>
              <p class="text-sm text-white/70">🤖 MiniMind 模型调用</p>
              <p class="text-[10px] text-white/30 mt-0.5">自训练轻量 LLM 对话</p>
            </a>
          </div>
        </div>

        <!-- Theme toggle -->
        <button id="theme-toggle" class="ml-auto md:ml-0 text-white/50 hover:text-white transition-colors" aria-label="Toggle theme">
          <img id="theme-icon" src="/off.svg" alt="theme" width="22" height="22" style="filter:invert(1)" />
        </button>
        <script is:inline>
          (function(){
            var btn=document.getElementById('theme-toggle');
            var icon=document.getElementById('theme-icon');
            var smiley=document.querySelector('header img[src*=\"smiley\"]');
            function setTheme(light){
              document.documentElement.classList.toggle('light',light);
              localStorage.setItem('theme',light?'light':'dark');
              icon.src=light?'/on.svg':'/off.svg';
              icon.style.filter=light?'invert(0)':'invert(1)';
              if(smiley)smiley.style.filter=light?'none':'invert(47%) sepia(96%) saturate(3590%) hue-rotate(190deg) brightness(101%) contrast(101%)';
            }
            setTheme(document.documentElement.classList.contains('light'));
            btn.onclick=function(){setTheme(!document.documentElement.classList.contains('light'))};
          })();
        </script>

        <!-- Mobile hamburger (only < 640px) -->
        <label for="menu-toggle" class="spacex-hamburger hidden max-sm:flex flex-col items-center justify-center">
          <span></span><span></span><span></span>
        </label>
      </div>
    </header>

    <!-- Mobile menu overlay -->
    <div id="mobile-menu" class="fixed inset-0 z-[90] bg-black/80 backdrop-blur-md flex-col items-center justify-center gap-6" style="display:none">
      <a href="/tags/" class="text-2xl text-white/70 hover:text-white transition-colors font-semibold tracking-wide" onclick="document.getElementById('mobile-menu').style.display='none';document.getElementById('menu-toggle').checked=false">Tags</a>
      <a href="/archives/" class="text-2xl text-white/70 hover:text-white transition-colors font-semibold tracking-wide" onclick="document.getElementById('mobile-menu').style.display='none';document.getElementById('menu-toggle').checked=false">Archives</a>
      <a href="/about/" class="text-2xl text-white/70 hover:text-white transition-colors font-semibold tracking-wide" onclick="document.getElementById('mobile-menu').style.display='none';document.getElementById('menu-toggle').checked=false">About</a>
      <a href="/radio/" class="text-2xl text-white/70 hover:text-white transition-colors font-semibold tracking-wide" onclick="document.getElementById('mobile-menu').style.display='none';document.getElementById('menu-toggle').checked=false">Gadgets</a>

      <!-- Language -->
      <div class="flex gap-3 mt-4">
        <button class="lang-btn text-xs text-white/30 hover:text-white/70 transition-colors active" onclick="window._setLang('zh')">中</button>
        <button class="lang-btn text-xs text-white/30 hover:text-white/70 transition-colors" onclick="window._setLang('en')">EN</button>
        <button class="lang-btn text-xs text-white/30 hover:text-white/70 transition-colors" onclick="window._setLang('emoji')">😀</button>
        <button class="lang-btn text-xs text-white/30 hover:text-white/70 transition-colors" onclick="window._setLang('kaomoji')">(´・ω・`)</button>
      </div>

      <!-- Upcoming -->
      <div class="mt-6 pt-6 border-t border-white/10 text-center">
        <p class="text-[10px] text-white/20 uppercase tracking-[0.2em] mb-2">UPCOMING</p>
        <p class="text-xs text-white/20">Godot 小游戏 · MiniMind 模型调用</p>
      </div>
    </div>

    <div class="relative z-10 w-full px-4 md:px-8 xl:px-16 2xl:px-24 pt-24 pb-16">
      <div class="flex gap-8">
        <!-- Desktop sidebar (always visible md+) -->
        <aside id="sidebar" class="w-64 shrink-0 hidden md:block">
          <div class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto space-y-6">
            <SidebarContent />
          </div>
        </aside>

        <!-- Main area -->
        <main id="main" class="flex-1 min-w-0 pb-16">
          <slot />
        </main>
      </div>
    </div>

    <footer class="relative z-10 flex justify-center items-center gap-3 text-white/40 text-xs py-8">
      <a href="mailto:bingtao2077@gmail.com" class="hover:text-white/60 transition-colors" title="Email">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 4-10 8L2 4"/></svg>
      </a>
      <span>|</span>
      <a href="https://www.zhihu.com/people/liu-run-run-28" target="_blank" class="hover:text-white/60 transition-colors">知乎</a>
      <span>|</span>
      <a href="https://github.com/yahoofunny/blog" target="_blank" class="hover:text-white/60 transition-colors" title="GitHub">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.604-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
      </a>
      <span>&mdash; {siteConfig.title} &copy; {new Date().getFullYear()}</span>
    </footer>

    <div id="clawd-pet" class="clawd-pet" title="Clawd"><img id="clawd-img" src="/clawd/clawd-idle.gif" style="width:100px;height:100px" draggable="false"/></div>
    <div id="clawd-speech" class="clawd-speech"></div>
    <script is:inline>
(function(){
var p=document.getElementById("clawd-pet"),b=document.getElementById("clawd-speech"),i=document.getElementById("clawd-img");
if(!p||!b||!i)return;
var gifs=["idle","idle","idle-reading","idle-reading","thinking","idle","conducting","idle-reading","typing","thinking","sweeping","idle","headphones-groove","juggling","sleeping","happy","error","building","carrying","notification","bubble"];
function rnd(){i.src="/clawd/clawd-"+gifs[Math.floor(Math.random()*gifs.length)]+".gif"}
setInterval(rnd,10000);rnd();
var qs=["Hello!","今天过得咋样","写代码了吗","早点睡别熬夜","bt最棒","🦞","金鳞岂是池中物","你是bt的朋友吗","欢迎来到bt的网站","你是bt要等的人吗","一起加油呀","有什么需要帮忙的吗","这个博客真不错","我喜欢这里的音乐","好久不见呀","bt今天又更新博客了吗","bt是个有趣的灵魂","跟着bt学数据结构","bt写代码的样子很帅","这里永远是bt的精神自留地","bt等你很久了","bt的朋友就是我的朋友","有问题尽管问bt","bt的电路笔记超详细","bt说早点睡别熬夜"];
function spk(){var t=qs[Math.floor(Math.random()*qs.length)];b.textContent=t;b.style.opacity="1";var r=p.getBoundingClientRect();b.style.left=Math.max(10,r.left-50)+"px";b.style.top=Math.max(10,r.top-40)+"px";clearTimeout(b._t);b._t=setTimeout(function(){b.style.opacity="0"},3000)}
setInterval(function(){if(!document.hidden&&Math.random()<0.3)spk()},120000);
var dr=false,cx=0,cy=0,sx=0,sy=0,moved=false;
function dragStart(x,y,t){
  dr=true;moved=false;var r=p.getBoundingClientRect();
  cx=r.left;cy=r.top;sx=x;sy=y;
  p.style.animation="none";p.style.transition="none";
  p.style.bottom="auto";p.style.right="auto";
  p.style.left=cx+"px";p.style.top=cy+"px";
  p.style.transform="translate(0,0)";
}
function dragMove(x,y){
  if(!dr)return;moved=true;
  p.style.transform="translate("+(x-sx)+"px,"+(y-sy)+"px)";
}
function dragEnd(x,y){
  if(!dr)return;dr=false;
  var dx=x-sx,dy=y-sy;
  // Commit position
  p.style.left=(cx+dx)+"px";p.style.top=(cy+dy)+"px";
  p.style.transform="";
  p.style.transition="";
  p.style.animation="clawd-float 3s ease-in-out infinite";
  if(!moved){rnd();spk()}
}
p.onmousedown=function(e){dragStart(e.clientX,e.clientY,e)};
p.ontouchstart=function(e){var t=e.touches[0];dragStart(t.clientX,t.clientY,e)};
window.onmousemove=function(e){dragMove(e.clientX,e.clientY)};
window.ontouchmove=function(e){var t=e.touches[0];dragMove(t.clientX,t.clientY);if(dr)t.preventDefault()};
window.onmouseup=function(e){dragEnd(e.clientX,e.clientY)};
window.ontouchend=function(e){if(!dr)return;dr=false;
  if(!moved){p.style.left=cx+"px";p.style.top=cy+"px";rnd();spk()}
  p.style.transform="";
  p.style.transition="";
  p.style.animation="clawd-float 3s ease-in-out infinite";};
p.ondblclick=spk;var lt=0;
var pv=parseInt(localStorage.getItem("cv")||0)+1;localStorage.setItem("cv",pv);
if(pv===1)setTimeout(spk,4000);
})();
    </script>
</body>

</html>
