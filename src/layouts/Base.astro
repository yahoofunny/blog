---
import BaseHead from "@/components/BaseHead.astro";
import SidebarContent from "@/components/SidebarContent.astro";
import { siteConfig } from "@/site.config";
import type { SiteMeta } from "@/types";

interface Props {
  meta: SiteMeta;
}

const { meta } = Astro.props;
const { articleDate, description = siteConfig.description, ogImage, title } = meta;
---

<html class="scroll-smooth" lang={siteConfig.lang}>
  <head>
    <BaseHead articleDate={articleDate} description={description} ogImage={ogImage} title={title} />
  </head>
  <body class="spacex-body min-h-screen text-white">
    <div class="video-bg">
      <video autoplay muted loop playsinline>
        <source src="/spacex.mp4" type="video/mp4" />
      </video>
    </div>
    <div class="video-overlay"></div>

    <header class="glass-header">
      <div class="max-w-7xl mx-auto px-6 flex items-center h-16">
        <button id="sidebar-btn" class="text-white/70 hover:text-white mr-4 lg:hidden" aria-label="Toggle sidebar" onclick="window._toggleSidebar()">
          <svg id="sb-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
        <a href="/" class="text-lg font-bold tracking-wider uppercase">{siteConfig.title}</a>
        <nav class="flex gap-4 text-sm ml-auto items-center">
          <a href="/" class="nav-link">Home</a>
          <a href="/tags/" class="nav-link">Tags</a>
          <a href="/archives/" class="nav-link">Archives</a>
          <a href="/about/" class="nav-link">About</a>
          <a href="/radio/" class="nav-link">Gadgets</a>
          <a href="https://github.com/yahoofunny/liquid-glasses-template-for-blog" target="_blank" class="nav-link opacity-70 hover:opacity-100" title="GitHub">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.604-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
            </svg>
          </a>
        </nav>
      </div>
    </header>

    <div class="relative z-10 max-w-7xl mx-auto px-6 pt-24 pb-16">
      <div class="flex gap-8">
        <!-- Mobile overlay + drawer -->
        <div id="sidebar-overlay" class="fixed inset-0 bg-black/60 z-40 hidden" aria-hidden="true"></div>
        <aside id="sidebar-mobile" class="fixed top-0 left-0 h-full w-72 z-50 -translate-x-full transition-transform duration-300 bg-black/90 backdrop-blur-xl border-r border-white/10 !p-6 pt-20 overflow-y-auto lg:hidden">
          <SidebarContent />
        </aside>

        <!-- Desktop sidebar -->
        <aside id="sidebar" class="w-64 shrink-0 hidden md:block">
          <div class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto space-y-6">
            <SidebarContent />
          </div>
        </aside>

        <!-- Main area -->
        <main id="main" class="flex-1 min-w-0 pb-16">
          <slot />
        </main>
      </div>
    </div>

    <footer class="relative z-10 flex justify-center items-center gap-3 text-white/40 text-xs py-8">
      <a href="mailto:bingtao2077@gmail.com" class="hover:text-white/60 transition-colors" title="Email">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 4-10 8L2 4"/></svg>
      </a>
      <span>|</span>
      <a href="https://www.zhihu.com/people/liu-run-run-28" target="_blank" class="hover:text-white/60 transition-colors">知乎</a>
      <span>&mdash; {siteConfig.title} &copy; {new Date().getFullYear()}</span>
    </footer>

    <script is:inline>
      var _sidebarOpen = false;
      window._toggleSidebar = function() {
        var s = document.getElementById('sidebar-mobile');
        var o = document.getElementById('sidebar-overlay');
        var i = document.getElementById('sb-icon');
        _sidebarOpen = !_sidebarOpen;
        if (_sidebarOpen) {
          if (s) s.style.transform = 'translateX(0)';
          if (o) o.classList.remove('hidden');
          if (i) i.innerHTML = '<line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/>';
        } else {
          if (s) s.style.transform = 'translateX(-100%)';
          if (o) o.classList.add('hidden');
          if (i) i.innerHTML = '<line x1=\"3\" y1=\"6\" x2=\"21\" y2=\"6\"/><line x1=\"3\" y1=\"12\" x2=\"21\" y2=\"12\"/><line x1=\"3\" y1=\"18\" x2=\"21\" y2=\"18\"/>';
        }
      };
      var overlay = document.getElementById('sidebar-overlay');
      if (overlay) overlay.addEventListener('click', window._toggleSidebar);
    </script>

    <div id="clawd-pet" class="clawd-pet" title="Clawd"><img id="clawd-img" src="/clawd/clawd-idle.gif" style="width:100px;height:100px" draggable="false"/></div>
    <div id="clawd-speech" class="clawd-speech"></div>
    <script is:inline>
(function(){
var p=document.getElementById("clawd-pet"),b=document.getElementById("clawd-speech"),i=document.getElementById("clawd-img");
if(!p||!b||!i)return;
var gifs=["idle","idle","idle-reading","idle-reading","thinking","idle","conducting","idle-reading","typing","thinking","sweeping","idle","headphones-groove","juggling","sleeping","happy","error","building","carrying","notification","bubble"];
function rnd(){i.src="/clawd/clawd-"+gifs[Math.floor(Math.random()*gifs.length)]+".gif"}
setInterval(rnd,10000);rnd();
var qs=["Hello!","今天过得咋样","写代码了吗","早点睡别熬夜","bt最棒","🦞","金鳞岂是池中物"];
function spk(){var t=qs[Math.floor(Math.random()*qs.length)];b.textContent=t;b.style.opacity="1";var r=p.getBoundingClientRect();b.style.left=Math.max(10,r.left-50)+"px";b.style.top=Math.max(10,r.top-40)+"px";clearTimeout(b._t);b._t=setTimeout(function(){b.style.opacity="0"},3000)}
setInterval(function(){if(!document.hidden&&Math.random()<0.3)spk()},120000);
var dr=false,ox=0,oy=0;
p.onmousedown=function(e){dr=true;ox=e.clientX-p.offsetLeft;oy=e.clientY-p.offsetTop;p.style.animation="none";e.preventDefault()};
p.ontouchstart=function(e){dr=true;var t=e.touches[0];ox=t.clientX-p.offsetLeft;oy=t.clientY-p.offsetTop;p.style.animation="none";e.preventDefault()};
window.onmousemove=function(e){if(!dr)return;p.style.left=(e.clientX-ox)+"px";p.style.top=(e.clientY-oy)+"px";p.style.bottom="auto";p.style.right="auto"};
window.ontouchmove=function(e){if(!dr)return;var t=e.touches[0];p.style.left=(t.clientX-ox)+"px";p.style.top=(t.clientY-oy)+"px";p.style.bottom="auto";p.style.right="auto"};
window.onmouseup=function(){if(dr){dr=false;setTimeout(function(){p.style.animation="clawd-float 3s ease-in-out infinite"},300)}};
window.ontouchend=function(){if(dr){dr=false;setTimeout(function(){p.style.animation="clawd-float 3s ease-in-out infinite"},300)}};
p.ondblclick=spk;var lt=0;p.addEventListener("touchend",function(e){var n=Date.now();if(n-lt<400&&!dr)spk();lt=n});
var pv=parseInt(localStorage.getItem("cv")||0)+1;localStorage.setItem("cv",pv);
if(pv===1)setTimeout(spk,4000);
})();
    </script>
</body>

</html>
