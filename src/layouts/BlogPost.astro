---
import { type CollectionEntry, render } from "astro:content";
import BaseLayout from "./Base.astro";
import { getFormattedDate } from "@/utils/date";

interface Props {
  post: CollectionEntry<"post">;
}

const { post } = Astro.props;
const { ogImage, title, description, updatedDate, publishDate, tags } = post.data;
const socialImage = ogImage ?? `/og-image/${post.id}.png`;
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString();

// Estimate reading time
const { headings } = await render(post);
const bodyText = post.body || "";
const wordCount = bodyText.replace(/\s+/g, "").length;
const readingTime = Math.max(1, Math.round(wordCount / 400));

// Build TOC
let tocHtml = '<p class="text-white/30 italic text-xs">No sections</p>';
if (headings.length > 0) {
  tocHtml = headings.map((h: any) =>
    `<a href="#${h.slug}" class="block text-white/50 hover:text-white py-0.5 transition-colors text-xs" style="padding-left:${(h.depth-1)*0.8}rem">${h.text}</a>`
  ).join('');
}
---

<BaseLayout meta={{ articleDate, description, ogImage: socialImage, title }}>
  <article class="glass-card !p-8 md:!p-12">
    <header class="mb-10">
      <h1 class="text-3xl md:text-4xl font-bold mb-3">{title}</h1>
      <!-- Chirpy-style post meta -->
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-white/40">
        <time datetime={publishDate.toISOString()}>
          <svg class="inline-block w-3.5 h-3.5 mr-1 -mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          {getFormattedDate(publishDate, { year: "numeric", month: "long", day: "numeric" })}
        </time>
        <span>·</span>
        <span>
          <svg class="inline-block w-3.5 h-3.5 mr-1 -mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/>
          </svg>
          {readingTime} min read
        </span>
        {tags.length > 0 && (
          <>
            <span>·</span>
            <span class="flex flex-wrap items-center gap-1">
              <svg class="inline-block w-3.5 h-3.5 mr-0.5 -mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/>
              </svg>
              {tags.map((tag, i) => (
                <span>
                  <a href={`/tags/${tag}/`} class="hover:text-white/70 transition-colors">{tag}</a>
                  {i < tags.length - 1 ? <span class="text-white/20">,</span> : ""}
                </span>
              ))}
            </span>
          </>
        )}
      </div>
      {updatedDate && updatedDate > publishDate && (
        <p class="text-xs text-white/25 mt-2 italic">
          Updated: {getFormattedDate(updatedDate, { year: "numeric", month: "long", day: "numeric" })}
        </p>
      )}
    </header>

    <div class="prose max-w-none">
      <slot />
    </div>
  </article>

  <!-- Floating TOC (desktop) -->
  <div id="floating-toc" class="hidden xl:block fixed bottom-24 right-24 z-50 max-w-[220px]">
    <div class="glass-card !p-3 !rounded-xl">
      <h3 class="text-[10px] font-semibold text-white/40 uppercase tracking-widest mb-2">On This Page</h3>
      <nav id="floating-toc-nav" class="text-[11px] space-y-0.5 max-h-[40vh] overflow-y-auto">
        {tocHtml !== '<p class="text-white/30 italic text-xs">No sections</p>' ? tocHtml : '<p class="text-white/30 italic text-[11px]">No sections</p>'}
      </nav>
    </div>
  </div>

  <!-- Giscus Comments -->
  <div class="glass-card !p-6 mt-8">
    <script src="https://giscus.app/client.js"
      data-repo="yahoofunny/blog"
      data-repo-id="R_kgDOS56yEA"
      data-category="General"
      data-category-id="DIC_kwDOS56yEM4DABSb"
      data-mapping="pathname"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="bottom"
      data-theme="dark_dimmed"
      data-lang="zh-CN"
      crossorigin="anonymous"
      async>
    </script>
  </div>

  <div class="text-center mt-8">
    <a href="/" class="text-white/40 hover:text-white/70 transition-colors text-sm">&larr; Back to Home</a>
  </div>
</BaseLayout>

<script define:vars={{ tocHtml }}>
  // Fill all TOC navs (desktop + mobile sidebar both render SidebarContent)
  document.querySelectorAll('#toc-nav').forEach(function(el) { el.innerHTML = tocHtml; });
</script>

<style>
  /* Move Clawd pet up when floating TOC is present */
  @media (min-width: 1280px) {
    #floating-toc {
      display: block !important;
    }
    #clawd-pet {
      bottom: 180px !important;
    }
  }
</style>
