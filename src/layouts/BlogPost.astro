---
import { type CollectionEntry, render } from "astro:content";
import BaseLayout from "./Base.astro";

interface Props {
  post: CollectionEntry<"post">;
}

const { post } = Astro.props;
const { ogImage, title, description, updatedDate, publishDate } = post.data;
const socialImage = ogImage ?? `/og-image/${post.id}.png`;
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString();
const { headings } = await render(post);
---

<BaseLayout meta={{ articleDate, description, ogImage: socialImage, title }}>
  <!-- Inject TOC via SSR - hidden, will be copied by BaseLayout script -->
  <template id="toc-data">
    {headings.length > 0 ? (
      headings.map((h) => (
        <a href={`#${h.slug}`} class="block text-white/50 hover:text-white py-0.5 transition-colors text-xs" style={`padding-left:${(h.depth - 1) * 0.8}rem`}>{h.text}</a>
      ))
    ) : (
      <p class="text-white/30 italic text-xs">No sections</p>
    )}
  </template>

  <article class="glass-card !p-8 md:!p-12">
    <header class="mb-10">
      <h1 class="text-3xl md:text-4xl font-bold mb-3">{title}</h1>
      <p class="text-white/40 text-sm uppercase tracking-wider">
        {publishDate.toLocaleDateString("zh-CN", { year: "numeric", month: "long", day: "numeric" })}
      </p>
    </header>

    <div class="prose max-w-none">
      <slot />
    </div>
  </article>

  <div class="text-center mt-8">
    <a href="/" class="text-white/40 hover:text-white/70 transition-colors text-sm">&larr; Back to Home</a>
  </div>
</BaseLayout>

<script>
  // Copy SSR-generated TOC to sidebar
  document.addEventListener('DOMContentLoaded', () => {
    const template = document.getElementById('toc-data');
    const tocNav = document.getElementById('toc-nav');
    if (template && tocNav) {
      tocNav.innerHTML = template.innerHTML;
      // Also update mobile sidebar
      const mobileToc = document.querySelector('#sidebar-mobile #toc-nav');
      if (mobileToc) mobileToc.innerHTML = template.innerHTML;
    }
  });
</script>
