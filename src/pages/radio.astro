---
import PageLayout from "@/layouts/Base.astro";
const meta = { description: "Claude FM - Lo-fi 24/7 Radio", title: "Claude FM" };
---

<PageLayout meta={meta}>
  <div class="glass-card !p-8 text-center">
    <h1 class="text-2xl font-bold mb-2">Claude FM</h1>
    <p class="text-white/50 text-sm mb-6">24/7 Lo-fi & Ambient</p>
    <audio controls autoplay class="w-full max-w-md mx-auto">
      <source src="https://lofi.stream.laut.fm/lofi" type="audio/mpeg" />
    </audio>
    <p class="text-white/30 text-xs mt-4">Powered by laut.fm</p>

	  <div class="glass-card !p-8 text-center mt-4">
	    <h2 class="text-xl font-bold mb-4">📸 Telegraph 图床</h2>
	    <p class="text-white/50 text-sm mb-4">给我发图片，点击下方按钮上传</p>
	    <a href="https://telegraph-image-download.pages.dev" target="_blank" class="inline-block px-6 py-3 bg-white/10 hover:bg-white/20 rounded-xl text-white text-sm transition-colors">
	      打开图床 →
	    </a>
	  </div>

	  <div class="glass-card !p-8 text-center mt-4">
	    <h2 class="text-xl font-bold mb-2">🌑 Drone Zone</h2>
	    <p class="text-white/50 text-sm mb-6">Dark Ambient — 伤感空间音乐</p>
	    <audio controls class="w-full max-w-md mx-auto">
	      <source src="https://ice4.somafm.com/dronezone-128-mp3" type="audio/mpeg" />
	    </audio>
	    <p class="text-white/30 text-xs mt-4">SomaFM Drone Zone</p>
	  </div>
  </div>
</PageLayout>
