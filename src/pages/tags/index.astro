---
import { getAllPosts, getUniqueTagsWithCount } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";

const allPosts = await getAllPosts();
const tagsWithCount = getUniqueTagsWithCount(allPosts);

const meta = {
  description: "Browse all tags",
  title: "Tags",
};
---

<PageLayout meta={meta}>
  <div class="glass-card !p-8 md:!p-12">
    <h1 class="text-2xl md:text-3xl font-bold mb-2">Tags</h1>
    <p class="text-white/40 text-sm mb-8">{tagsWithCount.length} tags in total</p>
    <div class="flex flex-wrap gap-3">
      {tagsWithCount.map(([tag, count]) => (
        <a href={`/tags/${tag}/`} class="glass-card !px-4 !py-3 !rounded-xl inline-flex items-center gap-2 hover:!bg-white/[0.12] transition-colors">
          <span class="text-white font-medium">{tag}</span>
          <span class="text-white/30 text-xs bg-white/10 px-2 py-0.5 rounded-full">{count}</span>
        </a>
      ))}
    </div>
  </div>
</PageLayout>
