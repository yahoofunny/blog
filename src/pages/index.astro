---
import { type CollectionEntry } from "astro:content";
import { getAllPosts } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

const allPosts = await getAllPosts();
const latestPosts = allPosts
  .sort(collectionDateSort)
  .slice(0, 20) as CollectionEntry<"post">[];
---

<PageLayout meta={{ title: "Home" }}>
  <!-- Hero -->
  <section class="mb-16 text-center">
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4">
      bt's Blog
    </h1>
    <p class="text-white/50 text-lg tracking-wide">
    </p>
  </section>

  <!-- Posts -->
  <section>
    <div class="flex flex-col gap-4">
      {latestPosts.map((p) => (
        <a href={`/posts/${p.id}/`} class="glass-card block">
          <h2 class="text-xl font-semibold">{p.data.title}</h2>
          <p class="post-meta mt-1">
            {p.data.publishDate.toLocaleDateString("zh-CN", { year: "numeric", month: "long", day: "numeric" })}
          </p>
          {p.data.description && (
            <p class="post-desc">{p.data.description}</p>
          )}
        </a>
      ))}
    </div>
  </section>
</PageLayout>
