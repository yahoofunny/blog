---
import { type CollectionEntry } from "astro:content";
import { getAllPosts } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

const allPosts = await getAllPosts();
const latestPosts = allPosts
  .sort(collectionDateSort)
  .slice(0, 20) as CollectionEntry<"post">[];
---

<PageLayout meta={{ title: "Home" }}>
  <div class="flex gap-8 flex-col md:flex-row">
    <!-- Mobile toggle button -->
    <button id="sidebar-toggle" class="md:hidden glass-card !p-3 text-sm w-full text-left flex items-center gap-2">
      <svg id="toggle-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      <span>目录</span>
    </button>

    <!-- Sidebar -->
    <aside id="sidebar" class="md:w-72 shrink-0 hidden md:block">
      <div class="glass-card !p-4 md:sticky md:top-24">
        <h3 class="text-sm font-semibold text-white/60 uppercase tracking-wider mb-3">Posts</h3>
        <ul class="space-y-1">
          {latestPosts.map((p) => (
            <li>
              <a href={`/posts/${p.id}/`} class="block text-sm text-white/70 hover:text-white py-1 transition-colors truncate">
                {p.data.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </aside>

    <!-- Main content -->
    <div class="flex-1 min-w-0">
      <section class="mb-12 text-center md:text-left">
        <h1 class="text-2xl md:text-4xl font-bold tracking-tight mb-2">
          bt's Blog :)
        </h1>
        <p class="text-white/40 text-sm">冰涛的技术博客</p>
      </section>

      <div class="flex flex-col gap-4">
        {latestPosts.map((p) => (
          <a href={`/posts/${p.id}/`} class="glass-card block">
            <h2 class="text-lg font-semibold">{p.data.title}</h2>
            <p class="post-meta mt-1">
              {p.data.publishDate.toLocaleDateString("zh-CN", { year: "numeric", month: "long", day: "numeric" })}
            </p>
            {p.data.description && (
              <p class="post-desc mt-2">{p.data.description}</p>
            )}
          </a>
        ))}
      </div>
    </div>
  </div>
</PageLayout>

<script>
  const btn = document.getElementById('sidebar-toggle');
  const sidebar = document.getElementById('sidebar');
  const icon = document.getElementById('toggle-icon');
  if (btn && sidebar && icon) {
    btn.addEventListener('click', () => {
      if (!icon) return;
      sidebar.classList.toggle('hidden');
      icon.innerHTML = sidebar.classList.contains('hidden')
        ? '<line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>'
        : '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>';
    });
  }
</script>
