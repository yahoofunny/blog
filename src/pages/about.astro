---
import PageLayout from "@/layouts/Base.astro";
const meta = { description: "About", title: "About" };
---
<PageLayout meta={meta}>
  <div class="glass-card text-center !py-12">
    <h1 class="text-3xl font-bold mb-6">About</h1>
    <div class="prose max-w-none text-white/70">
      <p class="text-lg">技术博客，记录学习与成长。</p>
      <p>内容涵盖数据结构、算法、电路等课程笔记。</p>
    </div>
  </div>
</PageLayout>
