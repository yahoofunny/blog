---
import PageLayout from "@/layouts/Base.astro";

const meta = {
  description: "About bingtao's blog",
  title: "About",
};
---

<PageLayout meta={meta}>
  <div class="glass-card text-center !py-12">
    <h1 class="text-3xl font-bold mb-6">About</h1>
    <div class="prose max-w-none text-white/70">
      <p class="text-lg">冰涛的考研笔记博客。</p>
      <p>内容涵盖数据结构、算法等计算机核心课程。</p>
      <p class="mt-6">
        <a href="https://github.com/yahoofunny" target="_blank" rel="noreferrer" class="text-white/80 hover:text-white underline underline-offset-4">
          GitHub &rarr;
        </a>
      </p>
    </div>
  </div>
</PageLayout>
